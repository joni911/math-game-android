<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/result_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:id="@+id/result_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/result_title"
            android:textSize="36sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginVertical="30dp" />

        <!-- Player 1 Result Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:elevation="4dp"
            app:cardCornerRadius="20dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="25dp">

                <TextView
                    android:id="@+id/p1_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Player 1"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="15dp" />

                <TextView
                    android:id="@+id/p1_score"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Skor Akhir: 15"
                    android:textSize="20sp"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/p1_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅ Benar: 8\n❌ Salah: 2"
                    android:textSize="18sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/p1_encouragement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👍 Bagus! Coba lagi ya!"
                    android:textSize="16sp"
                    android:textColor="@android:color/darker_gray"
                    android:textStyle="italic" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Player 2 Result Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:elevation="4dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="25dp">

                <TextView
                    android:id="@+id/p2_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Player 2"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="15dp" />

                <TextView
                    android:id="@+id/p2_score"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Skor Akhir: 12"
                    android:textSize="20sp"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/p2_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅ Benar: 6\n❌ Salah: 4"
                    android:textSize="18sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/p2_encouragement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👍 Bagus! Coba lagi ya!"
                    android:textSize="16sp"
                    android:textColor="@android:color/darker_gray"
                    android:textStyle="italic" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btn_play_again"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="7dp"
                android:text="@string/btn_play_again"
                android:textSize="20sp"
                android:textStyle="bold"
                android:backgroundTint="@color/button_success"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btn_exit"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="7dp"
                android:text="@string/btn_exit"
                android:textSize="20sp"
                android:textStyle="bold"
                android:backgroundTint="@android:color/white"
                android:textColor="@android:color/black" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>