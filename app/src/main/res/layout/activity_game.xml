<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Player 1 Area (Top, Rotated 180°) -->
    <LinearLayout
        android:id="@+id/player1_area"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/player1_bg"
        android:rotation="180"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/question_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.45">

        <!-- Info Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/white"
            android:layout_margin="10dp"
            android:padding="15dp"
            android:elevation="4dp">

            <View
                android:id="@+id/player1_avatar"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@color/player1" />

            <TextView
                android:id="@+id/player1_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Player 1"
                android:textSize="20sp"
                android:textColor="@color/player1"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/player1_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textSize="28sp"
                android:textColor="@color/player1"
                android:textStyle="bold"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <!-- Answer Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="20dp">

            <Button
                android:id="@+id/player1_btn1"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="5"
                android:textSize="32sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/player1_btn2"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="6"
                android:textSize="32sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/player1_btn3"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="7"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Question Card (Center) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/question_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:elevation="8dp"
        app:cardCornerRadius="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:minWidth="280dp">

            <TextView
                android:id="@+id/level_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Level 1 • Soal 1"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/question_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3 + 2"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:gravity="center"
                android:layout_marginVertical="10dp" />

            <TextView
                android:id="@+id/timer_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏱️ 15"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/timer_normal"
                android:gravity="center"
                android:layout_marginTop="10dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Player 2 Area (Bottom, Normal) -->
    <LinearLayout
        android:id="@+id/player2_area"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/player2_bg"
        app:layout_constraintTop_toBottomOf="@id/question_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.45">

        <!-- Info Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/white"
            android:layout_margin="10dp"
            android:padding="15dp"
            android:elevation="4dp">

            <View
                android:id="@+id/player2_avatar"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@color/player2" />

            <TextView
                android:id="@+id/player2_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Player 2"
                android:textSize="20sp"
                android:textColor="@color/player2"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/player2_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textSize="28sp"
                android:textColor="@color/player2"
                android:textStyle="bold"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <!-- Answer Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="20dp">

            <Button
                android:id="@+id/player2_btn1"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="5"
                android:textSize="32sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/player2_btn2"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="6"
                android:textSize="32sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/player2_btn3"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="7"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>